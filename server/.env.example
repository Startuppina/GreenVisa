# Use `localhost` when the backend runs on the host machine.
# Use `db` only when the backend itself runs inside Docker Compose.
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=pass123
DB_NAME=green-visa

EMAIL_SENDER = "testmailsender@gmail.com"
PASS_SENDER =   "abcd efgh ijkl mnop"
SECRET_KEY = "hexsecretkey"

USERNAME_ADMIN = "ADMIN"
EMAIL_ADMIN = "testmailadmin@gmail.com"
PASS_ADMIN="adminpassword"

STRIPE_PRIVATE_KEY=stripe_private_key

CLIENT_URL = http://client-host.com:5173
SERVER_URL = http://server-host.com:8080

# OCR Document Processing
OCR_PROVIDER=google-document-ai
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_DOCUMENT_AI_LOCATION=eu

# Category-specific processor IDs (preferred)
GOOGLE_DOCUMENT_AI_TRANSPORT_PROCESSOR_ID=
GOOGLE_DOCUMENT_AI_TRANSPORT_PROCESSOR_VERSION=
GOOGLE_DOCUMENT_AI_APE_PROCESSOR_ID=
GOOGLE_DOCUMENT_AI_APE_PROCESSOR_VERSION=

# Legacy fallback for transport processor (used when TRANSPORT_PROCESSOR_ID is not set)
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
GOOGLE_DOCUMENT_AI_PROCESSOR_VERSION=

# Chatbot
OPENAI_API_KEY=
