# Frontend now calls same-origin paths (`/api`, `/uploaded_img`) via proxy.
# Keep empty unless you intentionally reintroduce absolute URLs.
VITE_REACT_SERVER_ADDRESS=

# Backend target for Vite dev proxy (used by vite.config.js, NOT by browser code).
# Default: http://localhost:8080 (local dev).
# In Docker Compose set to http://server:8080 (service name).
# VITE_BACKEND_TARGET=http://localhost:8080
